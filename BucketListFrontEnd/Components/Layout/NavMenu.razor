@inject NavigationManager Navigation

<div class="top-row ps-3 navbar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
    <div class="container-fluid">
        <a class="navbar-brand" href="" style="color: white; font-weight: 700; font-size: 22px;">🪣 BucketList</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column" style="background: linear-gradient(180deg, #667eea 0%, #764ba2 100%); height: 100%;">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" style="color: rgba(255,255,255,0.8);">
                <span>🏠</span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bucketlistitem" style="color: rgba(255,255,255,0.8);">
                <span>📋</span> Bucket list items
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="mijnlijst" style="color: rgba(255,255,255,0.8);">
                <span>⭐</span> Personal BucketList
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="login" style="color: rgba(255,255,255,0.8);">
                <span>🔑</span> Login
            </NavLink>
        </div>

        <div class="nav-item px-3 mt-auto" style="position: absolute; bottom: 20px; width: 100%;">
            <button @onclick="Logout" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.4); padding: 8px 16px; border-radius: 8px; cursor: pointer; width: 80%;">
                🚪 Logout
            </button>
        </div>
    </nav>
</div>

<style>
    .nav-link:hover {
        background: rgba(255,255,255,0.2) !important;
        border-radius: 8px;
        color: white !important;
    }

    .nav-link.active {
        background: rgba(255,255,255,0.3) !important;
        border-radius: 8px;
        color: white !important;
        font-weight: 600;
    }
</style>

@code {
    private void Logout()
    {
        Navigation.NavigateTo("/login");
    }
}