@page "/login"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="brand">
            <span class="brand-name">BucketList</span>
        </div>

        <div class="tabs">
            <button class="tab @(activeTab == "login" ? "active" : "")" @onclick='() => { activeTab = "login"; errorMessage = ""; successMessage = ""; }'>
                Inloggen
            </button>
            <button class="tab @(activeTab == "register" ? "active" : "")" @onclick='() => { activeTab = "register"; errorMessage = ""; successMessage = ""; }'>
                Registreren
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-error">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (activeTab == "login")
        {
            <div class="form-group">
                <label>Gebruikersnaam</label>
                <input type="text" placeholder="Jouw gebruikersnaam" @bind="userName" />
            </div>
            <div class="form-group">
                <label>Wachtwoord</label>
                <input type="password" placeholder="••••••••" @bind="pass" />
            </div>
            <button class="btn-primary" @onclick="LoginUser" disabled="@isLoading">
                @(isLoading ? "Bezig..." : "Inloggen →")
            </button>
        }

        @if (activeTab == "register")
        {
            <div class="form-group">
                <label>Gebruikersnaam</label>
                <input type="text" placeholder="Kies een gebruikersnaam" @bind="regUserName" />
            </div>
            <div class="form-group">
                <label>Wachtwoord</label>
                <input type="password" placeholder="••••••••" @bind="regPass" />
            </div>
            <div class="form-group">
                <label>Bevestig wachtwoord</label>
                <input type="password" placeholder="••••••••" @bind="regPassConfirm" />
            </div>
            <button class="btn-primary" @onclick="RegisterUser" disabled="@isLoading">
                @(isLoading ? "Bezig..." : "Account aanmaken →")
            </button>
        }

    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap');

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0a0a0f;
        background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(102, 51, 153, 0.25), transparent), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(51, 0, 102, 0.15), transparent);
        font-family: 'Syne', sans-serif;
        padding: 20px;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        padding: 44px 40px;
        backdrop-filter: blur(20px);
        box-shadow: 0 0 0 1px rgba(255,255,255,0.03), 0 40px 80px rgba(0,0,0,0.6);
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 36px;
    }

    .brand-icon {
        font-size: 24px;
    }

    .brand-name {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
    }

    .tabs {
        display: flex;
        gap: 0;
        margin-bottom: 32px;
        background: rgba(255,255,255,0.04);
        border-radius: 10px;
        padding: 4px;
    }

    .tab {
        flex: 1;
        padding: 9px;
        border: none;
        background: transparent;
        color: rgba(255,255,255,0.4);
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 600;
        border-radius: 7px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .tab.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
        }

        .tab:hover:not(.active) {
            color: rgba(255,255,255,0.7);
        }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.45);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            margin-bottom: 8px;
            font-family: 'DM Mono', monospace;
        }

        .form-group input {
            width: 100%;
            padding: 13px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
            box-sizing: border-box;
        }

            .form-group input::placeholder {
                color: rgba(255,255,255,0.2);
            }

            .form-group input:focus {
                border-color: rgba(150, 80, 220, 0.6);
                background: rgba(255,255,255,0.07);
            }

    .btn-primary {
        width: 100%;
        padding: 14px;
        margin-top: 8px;
        background: linear-gradient(135deg, #7c3aed, #5b21b6);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.02em;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-primary:hover:not(:disabled) {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .alert {
        padding: 12px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-family: 'DM Mono', monospace;
        margin-bottom: 20px;
    }

    .alert-error {
        background: rgba(220, 53, 69, 0.12);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #f87171;
    }

    .alert-success {
        background: rgba(25, 135, 84, 0.12);
        border: 1px solid rgba(25, 135, 84, 0.3);
        color: #4ade80;
    }
</style>

@code {
    private string activeTab = "login";

    private string userName = "";
    private string pass = "";

    private string regUserName = "";
    private string regPass = "";
    private string regPassConfirm = "";

    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task LoginUser()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            var url = $"/login?username={Uri.EscapeDataString(userName)}&password={Uri.EscapeDataString(pass)}";
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<UserDto>();
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userId", user!.IdUser.ToString());
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userName", user.NameUser);
                Navigation.NavigateTo("/bucketlistitem");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Foute gebruikersnaam of wachtwoord.";
            }
            else
            {
                errorMessage = "Onbekende fout bij het inloggen.";
            }
        }
        catch
        {
            errorMessage = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RegisterUser()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(regUserName) || string.IsNullOrWhiteSpace(regPass))
        {
            errorMessage = "Vul alle velden in.";
            return;
        }

        if (regPass != regPassConfirm)
        {
            errorMessage = "Wachtwoorden komen niet overeen.";
            return;
        }

        isLoading = true;

        try
        {
            var url = $"/AddUser?userName={Uri.EscapeDataString(regUserName)}&password={Uri.EscapeDataString(regPass)}";
            var response = await Http.PostAsync(url, null);

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Account aangemaakt! Je kan nu inloggen.";
                regUserName = "";
                regPass = "";
                regPassConfirm = "";
                activeTab = "login";
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
            {
                errorMessage = "Deze gebruikersnaam is al in gebruik.";
            }
            else
            {
                errorMessage = "Onbekende fout bij het registreren.";
            }
        }
        catch
        {
            errorMessage = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class UserDto
    {
        public int IdUser { get; set; }
        public string NameUser { get; set; } = "";
    }
}
