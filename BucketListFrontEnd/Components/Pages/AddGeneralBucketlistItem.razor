@page "/bucketlistitem/add"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400&display=swap');

    .add-wrapper {
        max-width: 540px;
        margin: 0 auto;
        padding: 52px 28px;
    }

    .page-title {
        font-size: 34px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -1px;
        margin-bottom: 8px;
        padding-right: 60px;
    }

    .page-subtitle {
        color: rgba(255,255,255,0.3);
        font-size: 13px;
        font-family: 'DM Mono', monospace;
        margin-bottom: 40px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255,255,255,0.35);
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 8px;
            font-family: 'DM Mono', monospace;
        }

        .form-group input {
            width: 100%;
            padding: 13px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            color: #fff;
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s, background 0.2s;
        }

            .form-group input::placeholder {
                color: rgba(255,255,255,0.18);
            }

            .form-group input:focus {
                border-color: rgba(124, 58, 237, 0.5);
                background: rgba(255,255,255,0.07);
            }

    .btn-submit {
        width: 100%;
        padding: 14px;
        margin-top: 8px;
        background: linear-gradient(135deg, #7c3aed, #5b21b6);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-family: 'Syne', sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
    }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
</style>

<div class="add-wrapper">
    <div class="page-title">➕ Nieuw item</div>
    <div class="page-subtitle">voeg een item toe aan de algemene lijst en aan jou persoonlijke lijst</div>

    <div class="form-group">
        <label>Onderwerp</label>
        <input type="text" placeholder="bv.Dansen met matties" @bind="nameBucketListItem" />
    </div>

    <div class="form-group">
        <label>Beschrijving</label>
        <input type="text" placeholder="een korte omschrijving" @bind="descriptionBucketListItem" />
    </div>

    <button class="btn-submit" @onclick="addItemToDB">
        Item toevoegen →
    </button>
</div>

@code {
    private string nameBucketListItem = "";
    private string descriptionBucketListItem = "";

    private async void addItemToDB()
    {
        var url = $"bucketlistitem?itemName={Uri.EscapeDataString(nameBucketListItem)}&itemDescription={Uri.EscapeDataString(descriptionBucketListItem)}";
        var response = await Http.PostAsync(url, null);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/bucketlistitem");
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            await JS.InvokeVoidAsync("alert", "Dit item bestaat al!");
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Er trad een onbekende fout op!");
        }
    }
}
